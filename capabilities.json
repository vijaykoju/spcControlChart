{
    "dataRoles": [
        {
            "displayName": "Axis (date or category)",
            "name": "category",
            "kind": "Grouping"
        },
        {
            "displayName": "Measurement",
            "name": "measure",
            "kind": "Measure"
        },
        {
            "displayName": "Tooltip measures",
            "name": "tooltips",
            "kind": "Measure"
        },
        {
            "displayName": "Target",
            "name": "target",
            "kind": "Measure"
        },
        {
            "displayName": "Sample size / subgroup size",
            "name": "sampleSize",
            "kind": "Measure"
        },
        {
            "displayName": "Subgroup range or std dev",
            "name": "spread",
            "kind": "Measure"
        }
    ],
    "objects": {
        "chart": {
            "properties": {
                "chartType": { "type": { "enumeration": [] } }
            }
        },
        "chartParameters": {
            "properties": {
                "ewmaLambda": { "type": { "numeric": true } },
                "maWindow": { "type": { "numeric": true } },
                "cusumK": { "type": { "numeric": true } },
                "cusumH": { "type": { "numeric": true } },
                "showRaw": { "type": { "bool": true } },
                "rawColor": { "type": { "fill": { "solid": { "color": true } } } },
                "rawOpacity": { "type": { "numeric": true } },
                "rawSize": { "type": { "numeric": true } }
            }
        },
        "controlLimits": {
            "properties": {
                "sigmaMultiplier": { "type": { "numeric": true } },
                "floorLcl": { "type": { "bool": true } }
            }
        },
        "phaseDetection": {
            "properties": {
                "enableDetection": { "type": { "bool": true } },
                "significanceThreshold": { "type": { "numeric": true } },
                "minSegment": { "type": { "numeric": true } },
                "useManualChangepoint": { "type": { "bool": true } },
                "manualChangepoint": { "type": { "numeric": true } }
            }
        },
        "rules": {
            "properties": {
                "rule1": { "type": { "bool": true } },
                "rule2": { "type": { "bool": true } },
                "rule3": { "type": { "bool": true } },
                "rule4": { "type": { "bool": true } },
                "rule5": { "type": { "bool": true } },
                "rule6": { "type": { "bool": true } },
                "rule7": { "type": { "bool": true } },
                "rule8": { "type": { "bool": true } }
            }
        },
        "ruleReference": {
            "properties": {
                "show": { "type": { "bool": true } },
                "position": { "type": { "enumeration": [] } },
                "textColor": { "type": { "fill": { "solid": { "color": true } } } }
            }
        },
        "mrChart": {
            "properties": {
                "showMrChart": { "type": { "bool": true } },
                "heightRatio": { "type": { "numeric": true } }
            }
        },
        "legend": {
            "properties": {
                "show": { "type": { "bool": true } },
                "position": { "type": { "enumeration": [] } },
                "textColor": { "type": { "fill": { "solid": { "color": true } } } },
                "labelDataLine": { "type": { "text": true } },
                "labelCenter": { "type": { "text": true } },
                "labelLimits": { "type": { "text": true } },
                "labelZoneA": { "type": { "text": true } },
                "labelZoneB": { "type": { "text": true } },
                "labelZoneC": { "type": { "text": true } },
                "labelViolation": { "type": { "text": true } },
                "labelTarget": { "type": { "text": true } },
                "labelPhaseChange": { "type": { "text": true } }
            }
        },
        "annotations": {
            "properties": {
                "showPhaseChangeLine": { "type": { "bool": true } },
                "phaseChangeColor": { "type": { "fill": { "solid": { "color": true } } } },
                "showTargetLine": { "type": { "bool": true } },
                "targetColor": { "type": { "fill": { "solid": { "color": true } } } },
                "dataLabels": { "type": { "enumeration": [] } },
                "dataLabelColor": { "type": { "fill": { "solid": { "color": true } } } }
            }
        },
        "appearance": {
            "properties": {
                "lineColor": { "type": { "fill": { "solid": { "color": true } } } },
                "violationColor": { "type": { "fill": { "solid": { "color": true } } } },
                "limitColor": { "type": { "fill": { "solid": { "color": true } } } },
                "centerColor": { "type": { "fill": { "solid": { "color": true } } } },
                "zoneAColor": { "type": { "fill": { "solid": { "color": true } } } },
                "zoneBColor": { "type": { "fill": { "solid": { "color": true } } } },
                "zoneCColor": { "type": { "fill": { "solid": { "color": true } } } },
                "violationShape": { "type": { "enumeration": [] } },
                "pointShape": { "type": { "enumeration": [] } },
                "pointSize": { "type": { "numeric": true } },
                "pointOpacity": { "type": { "numeric": true } },
                "showZones": { "type": { "bool": true } },
                "showZoneLabels": { "type": { "bool": true } }
            }
        }
    },
    "dataViewMappings": [
        {
            "conditions": [
                {
                    "category": { "max": 1 },
                    "measure": { "max": 1 },
                    "target": { "max": 1 },
                    "sampleSize": { "max": 1 },
                    "spread": { "max": 1 }
                }
            ],
            "categorical": {
                "categories": {
                    "for": {
                        "in": "category"
                    },
                    "dataReductionAlgorithm": {
                        "top": { "count": 30000 }
                    }
                },
                "values": {
                    "select": [
                        { "bind": { "to": "measure" } },
                        { "bind": { "to": "target" } },
                        { "bind": { "to": "sampleSize" } },
                        { "bind": { "to": "spread" } },
                        { "for": { "in": "tooltips" } }
                    ]
                }
            }
        }
    ],
    "supportsLandingPage": true,
    "privileges": []
}
